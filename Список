class MyLinkedList<T> {
    private Node head;
    private Node tail;
    private int size;
    
    private class Node {
        T data;
        Node next;
        Node prev;
        
        Node(T data) {
            this.data = data;
            this.next = null;
            this.prev = null;
        }
    }
    
    public MyLinkedList() {
        head = null;
        tail = null;
        size = 0;
    }
    
    public void add(T value) {
        addLast(value);
    }
    
    public void addFirst(T value) {
        Node node = new Node(value);
        
        if (size == 0) {
            head = node;
            tail = node;
        } else {
            node.next = head;
            head.prev = node;
            head = node;
        }
        
        size++;
    }
    
    public void addLast(T value) {
        Node node = new Node(value);
        
        if (size == 0) {
            head = node;
            tail = node;
        } else {
            tail.next = node;
            node.prev = tail;
            tail = node;
        }
        
        size++;
    }
    
    public boolean remove(T value) {
        Node current = head;
        
        while (current != null) {
            if (current.data.equals(value)) {
                if (current.prev == null) {
                    head = current.next;
                    if (head != null) {
                        head.prev = null;
                    } else {
                        tail = null;
                    }
                } else if (current.next == null) {
                    tail = current.prev;
                    tail.next = null;
                } else {
                    current.prev.next = current.next;
                    current.next.prev = current.prev;
                }
                
                size--;
                return true;
            }
            current = current.next;
        }
        
        return false;
    }
    
    public void removeFirst() {
        if (size == 0) {
            return;
        }
        
        if (size == 1) {
            head = null;
            tail = null;
        } else {
            head = head.next;
            head.prev = null;
        }
        
        size--;
    }
    
    public void removeLast() {
        if (size == 0) {
            return;
        }
        
        if (size == 1) {
            head = null;
            tail = null;
        } else {
            tail = tail.prev;
            tail.next = null;
        }
        
        size--;
    }
    
    public boolean contains(T value) {
        Node current = head;
        
        while (current != null) {
            if (current.data.equals(value)) {
                return true;
            }
            current = current.next;
        }
        
        return false;
    }
    
    public void clear() {
        head = null;
        tail = null;
        size = 0;
    }
    
    public int size() {
        return size;
    }
    
    public boolean isEmpty() {
        return size == 0;
    }
    
    public void printList() {
        Node current = head;
        
        while (current != null) {
            System.out.print(current.data + " ");
            current = current.next;
        }
        System.out.println();
    }
    
    public void printListReverse() {
        Node current = tail;
        
        while (current != null) {
            System.out.print(current.data + " ");
            current = current.prev;
        }
        System.out.println();
    }
    
    public static void main(String[] args) {
        MyLinkedList<Integer> list = new MyLinkedList<>();
        
        list.add(10);
        list.add(20);
        list.add(30);
        list.add(40);
        list.add(50);
        
        System.out.println("Размер списка: " + list.size());
        
        System.out.print("Список: ");
        list.printList();
        
        System.out.print("Список в обратном порядке: ");
        list.printListReverse();
        
        list.addFirst(5);
        System.out.print("После addFirst(5): ");
        list.printList();
        
        list.addLast(60);
        System.out.print("После addLast(60): ");
        list.printList();
        
        System.out.println("\nСодержит 30? " + list.contains(30));
        System.out.println("Содержит 100? " + list.contains(100));
        
        System.out.println("\nУдаляем 30:");
        list.remove(30);
        list.printList();
        
        System.out.println("\nУдаляем первый элемент:");
        list.removeFirst();
        list.printList();
        
        System.out.println("\nУдаляем последний элемент:");
        list.removeLast();
        list.printList();
        
        System.out.println("\nРазмер списка: " + list.size());
        
        System.out.println("\nОчищаем список:");
        list.clear();
        System.out.println("Размер списка: " + list.size());
        System.out.println("Список пуст? " + list.isEmpty());
    }
}
